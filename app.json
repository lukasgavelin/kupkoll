{
  "expo": {
    "name": "Kupkoll",
    "slug": "kupkoll",
    "scheme": "kupkoll",
    "version": "1.2.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Kupkoll använder din plats för att spara bigårdens position på kartan."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.lukasgavelin.kupkoll",
      "versionCode": 1,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a45caa0d-ceea-4fd0-a894-c6941000f0fa"
      }
    },
    "owner": "mrwindle"
  }
}
